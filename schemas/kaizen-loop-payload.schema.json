{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kaizen-agents.org/schemas/builder-agent/kaizen-loop-payload.schema.json",
  "title": "KaizenLoopPayload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "summary",
    "notes"
  ],
  "allOf": [
    {
      "if": {
        "required": ["status"],
        "properties": {
          "status": {
            "const": "blocked"
          }
        }
      },
      "then": {
        "required": ["blockedReason"],
        "properties": {
          "blockedReason": {
            "minLength": 1,
            "pattern": "\\S"
          }
        }
      }
    },
    {
      "if": {
        "required": ["status"],
        "properties": {
          "status": {
            "enum": ["fixed", "partial"]
          }
        }
      },
      "then": {
        "properties": {
          "blockedReason": {
            "not": {
              "pattern": "\\S"
            }
          }
        }
      }
    },
    {
      "if": {
        "required": ["status"],
        "properties": {
          "status": {
            "const": "partial"
          }
        }
      },
      "then": {
        "properties": {
          "notes": {
            "minLength": 1,
            "pattern": "\\S"
          }
        }
      }
    },
    {
      "if": {
        "required": ["status"],
        "properties": {
          "status": {
            "enum": ["fixed", "partial"]
          }
        }
      },
      "then": {
        "not": {
          "required": ["humanRequest"]
        }
      }
    }
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": ["fixed", "partial", "blocked"],
      "description": "Result status consumed by kaizen-loop. Use fixed when the scoped implementation is complete, partial when reviewable code was produced but known non-blocking work remains for verifier or human review, and blocked when the builder cannot produce PR-worthy changes without more information, credentials, approval, or an upstream fix."
    },
    "summary": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S",
      "description": "Short implementation summary for the source issue or task."
    },
    "notes": {
      "type": "string",
      "description": "Verification run or skipped, residual risk, reviewer notes, and fallback evidence when relevant. For partial results this must be non-empty and identify completed scope, incomplete scope, verification status, and residual risk."
    },
    "blockedReason": {
      "type": "string",
      "description": "Reason the builder could not complete the task when status is blocked."
    },
    "humanRequest": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reasonCode", "requestKey", "question"],
      "description": "A concrete unanswered human question. Include only when status is blocked and work cannot continue without the answer or approval.",
      "properties": {
        "reasonCode": {
          "type": "string",
          "enum": [
            "missing_information",
            "credentials",
            "billing",
            "destructive_action",
            "production_change",
            "policy_exception",
            "external_repository_action",
            "other_approval"
          ]
        },
        "requestKey": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9._:-]*$",
          "description": "Stable semantic identity for the requested decision. Keep it unchanged when only question wording changes."
        },
        "question": {
          "type": "string",
          "minLength": 1,
          "pattern": "\\S"
        }
      }
    },
    "discoveredIssues": {
      "type": "array",
      "description": "Bugs or follow-up issues found while implementing this task. The orchestrator, not Builder Agent, may file these as GitHub issues.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "expected", "evidence"],
        "properties": {
          "title": {
            "type": "string",
            "minLength": 1
          },
          "body": {
            "type": "string",
            "minLength": 1
          },
          "expected": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          },
          "evidence": {
            "type": "string",
            "minLength": 1,
            "pattern": "\\S"
          },
          "repo": {
            "type": "string",
            "minLength": 1,
            "description": "Optional target repository or Kaizen component alias such as kaizen-loop, builder-agent, verifier, or .github."
          },
          "severity": {
            "type": "string",
            "minLength": 1
          },
          "labels": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
